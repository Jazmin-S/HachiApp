        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.HachiApp">
        <activity
            android:name=".ActivityVolante"
            android:exported="false" />
        <activity
            android:name=".ActivityChat"
            android:exported="false" />
        <activity
            android:name=".ActivityHistorial"
            android:exported="false" />
        <activity
            android:name=".ActivityMensajes"
            android:exported="false" />
        <activity
            android:name=".ActivityAlertas"
            android:exported="false" />
        <activity
            android:name=".ActivityInicio"
            android:exported="false" /> <!-- 🔥 PANTALLA INICIAL TEMPORAL: Login -->
        <activity
            android:name=".Activity_Login"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ActivityRegistro"
            android:exported="false" />
        <activity
            android:name=".ActivityContrasena"
            android:exported="false" />
        <activity
            android:name=".Activity_recuperacion"
            android:exported="false" />
        <activity
            android:name=".ActivityCodigo"
            android:exported="false" />
        <activity
            android:name=".ActivityMapa"
            android:exported="false" />
        <activity
            android:name=".ActivityPerfil"
            android:exported="false" />
        <activity android:name=".ActivityRegistroReporte"
            android:exported="false" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />
    </application>

</manifest>