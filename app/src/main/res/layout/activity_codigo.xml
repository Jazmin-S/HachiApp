<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E99D4F"
    tools:context=".ActivityCodigo">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="0dp"
        android:layout_height="105dp"
        android:background="#EDD5B6"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageView7"
            android:layout_width="174dp"
            android:layout_height="83dp"
            android:layout_weight="1"
            android:adjustViewBounds="false"
            app:srcCompat="@drawable/iconoprincipal" />

        <TextView
            android:id="@+id/textView5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="HachiApp"
            android:textColor="#000000"
            android:textSize="45sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/textcodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="39dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="39dp"
        android:text="Codigo de verificacion"
        android:textColor="#2E1B0E"
        android:textSize="34sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout" />


    <TextView
    android:id="@+id/textSubVerificacion"
    android:layout_width="273dp"
    android:layout_height="36dp"
    android:layout_marginStart="39dp"
    android:layout_marginTop="16dp"
    android:layout_marginEnd="39dp"
    android:text="Ingresa el codigo de 4 digitos que enviamos a tu correo"
    android:textAlignment="center"
    android:textColor="#2E1B0E"
    android:textSize="16sp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/textcodigo" />


    <EditText
        android:id="@+id/editTextCodigo1"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="45dp"
        android:layout_marginTop="75dp"
        android:layout_marginEnd="15dp"
        android:background="@drawable/bg_editartext_plantilla"
        android:gravity="center"
        android:inputType="number"
        android:maxLength="1"
        android:textSize="24sp"
        app:layout_constraintEnd_toStartOf="@+id/editTextCodigo2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textSubVerificacion" />

    <EditText
        android:id="@+id/editTextCodigo2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="75dp"
        android:layout_marginEnd="15dp"
        android:background="@drawable/bg_editartext_plantilla"
        android:gravity="center"
        android:inputType="number"
        android:maxLength="1"
        android:textSize="24sp"
        app:layout_constraintEnd_toStartOf="@+id/editTextCodigo3"
        app:layout_constraintStart_toEndOf="@+id/editTextCodigo1"
        app:layout_constraintTop_toBottomOf="@+id/textSubVerificacion" />

    <EditText
        android:id="@+id/editTextCodigo3"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="75dp"
        android:layout_marginEnd="15dp"
        android:background="@drawable/bg_editartext_plantilla"
        android:gravity="center"
        android:inputType="number"
        android:maxLength="1"
        android:textSize="24sp"
        app:layout_constraintEnd_toStartOf="@+id/editTextCodigo4"
        app:layout_constraintStart_toEndOf="@+id/editTextCodigo2"
        app:layout_constraintTop_toBottomOf="@+id/textSubVerificacion" />

    <EditText
        android:id="@+id/editTextCodigo4"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="75dp"
        android:layout_marginEnd="45dp"
        android:background="@drawable/bg_editartext_plantilla"
        android:gravity="center"
        android:inputType="number"
        android:maxLength="1"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/editTextCodigo3"
        app:layout_constraintTop_toBottomOf="@+id/textSubVerificacion" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerificar"
        android:layout_width="210dp"
        android:layout_height="48dp"
        android:layout_marginStart="131dp"
        android:layout_marginTop="25dp"
        android:layout_marginEnd="131dp"
        android:backgroundTint="#FFFFFF"
        android:text="Verificar código"
        android:textColor="#000000"
        android:textSize="16sp"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.508"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView3" />

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="207dp"
        android:layout_height="149dp"
        android:layout_marginStart="103dp"
        android:layout_marginTop="23dp"
        android:layout_marginEnd="103dp"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toTopOf="@+id/btnVerificar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextCodigo2"
        app:srcCompat="@drawable/gatito"/>

    <TextView
        android:id="@+id/ReenCodigo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:text="Reenviar Codigo"
        android:textColor="#000000"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnVerificar" />

</androidx.constraintlayout.widget.ConstraintLayout>