<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D79149"
    tools:context=".Activity.ActivityDetalleAvistamiento">

    <!-- HEADER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardHeader"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#EDD5B6"
            android:gravity="center_vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="339dp"
                android:layout_height="wrap_content"
                android:text="Avistamiento"
                android:textAlignment="center"
                android:textColor="#121111"
                android:textSize="34sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- IMAGEN -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardImagen"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/cardHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#000000">

        <ImageView
            android:id="@+id/imgAvistamientoDetalle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_camera_alt_24"
            android:background="#FFFFFF"/>
    </androidx.cardview.widget.CardView>

    <!-- INFO -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/cardImagen"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="#2B1E14">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- TIPO -->
                <TextView
                    android:id="@+id/tvTipoMascota"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo de mascota"
                    android:textColor="#0D0C0C"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- DESCRIPCIÓN LABEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Descripción"
                    android:textColor="#0B0A0A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="15sp"
                    android:layout_marginTop="4dp"
                    android:textColor="#0B0A0A"/>

                <!-- DIRECCIÓN LABEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dirección"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="14dp"
                    android:textColor="#0B0A0A"/>

                <TextView
                    android:id="@+id/tvDireccion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="15sp"
                    android:layout_marginTop="4dp"
                    android:textColor="#0B0A0A"/>

                <!-- BOTÓN -->
                <Button
                    android:id="@+id/btnCerrarAvistamiento"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Cerrar"
                    android:layout_marginTop="20dp"
                    android:backgroundTint="#E19039"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

        </ScrollView>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>