<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D79149"
    tools:context=".ActivityInicio">

    <!-- ================= HEADER ================= -->
    <androidx.cardview.widget.CardView
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F5E6D3">

            <ImageView
                android:id="@+id/logo"
                android:layout_width="93dp"
                android:layout_height="60dp"
                android:layout_marginStart="14dp"
                android:contentDescription="@string/logo_hachiapp"
                android:src="@drawable/iconoprincipal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/app_name"
                android:textColor="#000000"
                android:textSize="34sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/logo"/>

            <androidx.cardview.widget.CardView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                app:cardCornerRadius="29dp"
                app:cardElevation="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageButton
                    android:id="@+id/BtnPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/perfil"
                    android:backgroundTint="#FBF6F6"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/desc_perfil"
                    android:scaleType="centerCrop"
                    android:src="@drawable/perfil" />

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- ================= BUSCADOR ================= -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBuscar"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="82dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/LYBusqueda"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/desc_buscar"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#AAAAAA" />

            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_buscar_reporte"
                android:inputType="text"
                android:autofillHints="none"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="16sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ================= FILTRO ================= -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnFiltro"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_marginEnd="18dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toTopOf="@id/cardBuscar"
        app:layout_constraintBottom_toBottomOf="@id/cardBuscar"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnclasificar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:contentDescription="@string/desc_filtro"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#1A1A1A" />

    </androidx.cardview.widget.CardView>

    <!-- ================= CONTENIDO ================= -->

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardBuscar"
        app:layout_constraintBottom_toTopOf="@id/bottomContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp">

            <LinearLayout
                android:id="@+id/LYTarjetas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- ===== CARD 1 ===== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="165dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="50dp"
                            app:cardElevation="4dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/desc_mascota"
                                android:scaleType="centerCrop"
                                android:src="@drawable/images" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:id="@+id/NombreAnimal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/nombre_ejemplo_1"
                            android:textColor="#1A1A1A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/fechaanimal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/fecha_ejemplo_1"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="#F0F0F0" />

                        <TextView
                            android:id="@+id/estadoAnimal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#E8F5EE"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="@string/estado_visto"
                            android:textColor="#1B8C4E"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/VistasReporte"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/vistas_ejemplo_1"
                            android:textColor="#555555"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- ===== CARD 2 ===== -->
                <androidx.cardview.widget.CardView
                    android:layout_width="165dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="100dp"
                            android:layout_height="100dp"
                            app:cardCornerRadius="50dp"
                            app:cardElevation="4dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:contentDescription="@string/desc_mascota"
                                android:scaleType="centerCrop"
                                android:src="@drawable/img_gatos_encontrar_perdidos_trucos_3_art" />

                        </androidx.cardview.widget.CardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/nombre_ejemplo_2"
                            android:textColor="#1A1A1A"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/tiempo_ejemplo_2"
                            android:textColor="#888888"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="#F0F0F0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#FDECEA"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="@string/estado_perdido"
                            android:textColor="#C62828"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/vistas_ejemplo_2"
                            android:textColor="#555555"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ================= NAVIGATION BAR ================= -->

    <androidx.cardview.widget.CardView
        android:id="@+id/bottomContainer"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="#FFF6EC"
        app:cardCornerRadius="22dp"
        app:cardElevation="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <!-- INICIO -->
                <LinearLayout
                    android:id="@+id/BtnInicio"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/nav_inicio"
                        android:src="@drawable/home"
                        app:tint="#E19039" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/nav_inicio"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- MAPA -->
                <LinearLayout
                    android:id="@+id/BtnMapa"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/nav_mapa"
                        android:src="@drawable/mapa"
                        app:tint="#E19039" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/nav_mapa"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <Space
                    android:layout_width="90dp"
                    android:layout_height="match_parent" />

                <!-- ALERTAS -->
                <LinearLayout
                    android:id="@+id/BtnAlertas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/nav_alertas"
                        android:src="@drawable/alerta"
                        app:tint="#E19039" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/nav_alertas"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- HISTORIAL -->
                <LinearLayout
                    android:id="@+id/BtnHistorial"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:contentDescription="@string/nav_historial"
                        android:src="@drawable/historial"
                        app:tint="#E19039" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/nav_historial"
                        android:textColor="#222222"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- BOTÓN REPORTAR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnReportar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_centerHorizontal="true"
                app:cardBackgroundColor="#F0A04B"
                app:cardCornerRadius="36dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:id="@+id/BtnReporte"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_horizontal|bottom"
                    android:orientation="vertical"
                    android:paddingBottom="20dp">

                    <ImageView
                        android:id="@+id/imageView4"
                        android:layout_width="33dp"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="-1dp"
                        android:contentDescription="@string/desc_mascota"
                        app:srcCompat="@drawable/crea_un_archivo"
                        app:tint="#F4ECEC" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>