<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D79149"
    tools:context=".ActivityRegistro">

    <!-- HEADER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#EDD5B6">

            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="93dp"
                android:layout_height="63dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/iconoprincipal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="HachiApp"
                android:textColor="#000"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageView7"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

    <!-- FORM -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NOMBRE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre(s)"
                android:textColor="#000000"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/textNombre"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:padding="12dp"
                android:textColor="#000000"
                android:textSize="18sp" />

            <!-- APELLIDO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apellidos"
                android:textColor="#000000"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/textApellido"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:padding="12dp"
                android:textColor="#000000"
                android:textSize="18sp" />

            <!-- CORREO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Correo electrónico"
                android:textColor="#000000"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/textCorreo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:textColor="#000000"
                android:textSize="18sp" />

            <!-- CONTRASEÑA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contraseña"
                android:textColor="#000000"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/textContrasena"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="#000000"
                android:textSize="18sp" />

            <!-- TELEFONO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teléfono"
                android:textColor="#000000"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/textTelefono"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_campo"
                android:inputType="phone"
                android:padding="12dp"
                android:textColor="#000000"
                android:textSize="18sp" />

            <!-- IMAGEN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Imagen de perfil"
                android:textColor="#000000"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/textNombreImagen"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_campo"
                    android:clickable="true"
                    android:focusable="false"
                    android:hint="Seleccionar imagen"
                    android:padding="12dp"
                    android:textColor="#000000"
                    android:textSize="18sp" />

                <ImageButton
                    android:id="@+id/btnSeleccionarImagen"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:background="#E0E0E0"
                    android:src="@android:drawable/ic_menu_gallery" />
            </LinearLayout>

            <!-- PREVIEW -->
            <ImageView
                android:id="@+id/imgPreview"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:background="#E0E0E0"
                android:scaleType="centerCrop" />

            <!-- BOTON -->
            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#EDD5B7"
                android:text="Guardar"
                android:textColor="#000000"
                android:textSize="20sp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>