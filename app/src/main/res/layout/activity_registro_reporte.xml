<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D79149"
    tools:context=".Activity.ActivityRegistroReporte">

    <!-- HEADER -->
    <androidx.cardview.widget.CardView
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_margin="12dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#EDD5B6">

            <ImageView
                android:id="@+id/imageView7"
                android:layout_width="93dp"
                android:layout_height="60dp"
                android:layout_marginStart="30dp"
                android:src="@drawable/iconoprincipal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/textView5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-black"
                android:text="Reporte"
                android:textColor="#000000"
                android:textSize="34sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/imageView7"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.cardview.widget.CardView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:layout_marginEnd="14dp"
                app:cardCornerRadius="29dp"
                app:cardElevation="6dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageButton
                    android:id="@+id/BtnPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/perfil"
                    android:backgroundTint="#FBF6F6"
                    android:clickable="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/perfil" />

            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <!-- TÍTULO -->

    <!-- SCROLL PRINCIPAL -->

    <TextView
        android:id="@+id/tvTituloReporte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="108dp"
        android:layout_marginTop="8dp"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/headerCard" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@+id/tvTituloReporte"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFF6EC">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- FILA: Foto + Campos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Botón foto -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btnFoto"
                            android:layout_width="110dp"
                            android:layout_height="160dp"
                            android:layout_marginEnd="10dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="#E8E0D8">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <ImageView
                                    android:id="@+id/btnFotoReporte"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_camera_alt_24"
                                    app:tint="#1D1A1A" />

                                <!-- Miniaturas de imágenes seleccionadas (se llena por código) -->
                                <HorizontalScrollView
                                    android:layout_width="match_parent"
                                    android:layout_height="93dp"
                                    android:layout_marginTop="8dp"
                                    android:scrollbars="none">

                                    <LinearLayout
                                        android:id="@+id/layoutMiniaturas"
                                        android:layout_width="wrap_content"
                                        android:layout_height="80dp"
                                        android:gravity="center_vertical"
                                        android:orientation="horizontal" />

                                </HorizontalScrollView>

                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <!-- Campos derecha -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Tipo de mascota -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginBottom="6dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="#FFFFFF">

                                <Spinner
                                    android:id="@+id/spinnerTipoMascota"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="4dp"
                                    android:spinnerMode="dropdown"
                                    android:background="@null"
                                    android:entries="@array/tipos_mascota"
                                    android:prompt="@string/tipo_mascota_hint" />

                            </androidx.cardview.widget.CardView>

                            <!-- Nombre -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginBottom="6dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="#FFFFFF">

                                <EditText
                                    android:id="@+id/etNombreMascota"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@null"
                                    android:hint="Nombre de la mascota"
                                    android:textColorHint="#AAAAAA"
                                    android:textColor="#000000"
                                    android:textSize="13sp"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="8dp"
                                    android:inputType="textPersonName"
                                    android:gravity="center_vertical" />

                            </androidx.cardview.widget.CardView>

                            <!-- Raza -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_marginBottom="6dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="#FFFFFF">

                                <EditText
                                    android:id="@+id/etRazaMascota"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@null"
                                    android:hint="Raza de la mascota"
                                    android:textColorHint="#AAAAAA"
                                    android:textColor="#000000"
                                    android:textSize="13sp"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="8dp"
                                    android:inputType="text"
                                    android:gravity="center_vertical" />

                            </androidx.cardview.widget.CardView>

                            <!-- Color: texto + selector de color -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                app:cardCornerRadius="12dp"
                                app:cardElevation="2dp"
                                app:cardBackgroundColor="#FFFFFF">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="8dp">

                                    <EditText
                                        android:id="@+id/etColorMascota"
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:background="@null"
                                        android:hint="Color de la mascota"
                                        android:textColorHint="#AAAAAA"
                                        android:textColor="#000000"
                                        android:textSize="13sp"
                                        android:inputType="text"
                                        android:gravity="center_vertical" />

                                    <!-- Círculo de color seleccionado (se actualiza por código) -->
                                    <View
                                        android:id="@+id/viewColorPreview"
                                        android:layout_width="24dp"
                                        android:layout_height="24dp"
                                        android:layout_marginStart="6dp"
                                        android:background="@drawable/circle_color_preview"
                                        android:clickable="true"
                                        android:focusable="true" />

                                </LinearLayout>
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </LinearLayout>

                    <!-- PALETA DE COLORES -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="6dp"
                        android:text="Seleccionar color"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        android:textStyle="italic" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutPaletaColores"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Negro -->
                            <View android:id="@+id/colorNegro"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#1A1A1A"
                                android:clickable="true" android:focusable="true" />
                            <!-- Gris oscuro -->
                            <View android:id="@+id/colorGrisOscuro"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#555555"
                                android:clickable="true" android:focusable="true" />
                            <!-- Gris claro -->
                            <View android:id="@+id/colorGrisClaro"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#BBBBBB"
                                android:clickable="true" android:focusable="true" />
                            <!-- Blanco -->
                            <View android:id="@+id/colorBlanco"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#F5F5F5"
                                android:clickable="true" android:focusable="true" />
                            <!-- Café oscuro -->
                            <View android:id="@+id/colorCafeOscuro"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#4E2A04"
                                android:clickable="true" android:focusable="true" />
                            <!-- Café -->
                            <View android:id="@+id/colorCafe"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#8B4513"
                                android:clickable="true" android:focusable="true" />
                            <!-- Beige/Crema -->
                            <View android:id="@+id/colorBeige"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#D2B48C"
                                android:clickable="true" android:focusable="true" />
                            <!-- Dorado -->
                            <View android:id="@+id/colorDorado"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#DAA520"
                                android:clickable="true" android:focusable="true" />
                            <!-- Naranja -->
                            <View android:id="@+id/colorNaranja"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#E07020"
                                android:clickable="true" android:focusable="true" />
                            <!-- Amarillo -->
                            <View android:id="@+id/colorAmarillo"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#F5D000"
                                android:clickable="true" android:focusable="true" />
                            <!-- Rojo -->
                            <View android:id="@+id/colorRojo"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#CC2200"
                                android:clickable="true" android:focusable="true" />
                            <!-- Rosa -->
                            <View android:id="@+id/colorRosa"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#F4A0B0"
                                android:clickable="true" android:focusable="true" />
                            <!-- Azul -->
                            <View android:id="@+id/colorAzul"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#1565C0"
                                android:clickable="true" android:focusable="true" />
                            <!-- Azul claro -->
                            <View android:id="@+id/colorAzulClaro"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#64B5F6"
                                android:clickable="true" android:focusable="true" />
                            <!-- Verde -->
                            <View android:id="@+id/colorVerde"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#2E7D32"
                                android:clickable="true" android:focusable="true" />
                            <!-- Verde claro -->
                            <View android:id="@+id/colorVerdeClaro"
                                android:layout_width="32dp" android:layout_height="32dp"
                                android:background="@drawable/circle_color_swatch"
                                android:backgroundTint="#A5D6A7"
                                android:clickable="true" android:focusable="true" />

                        </LinearLayout>
                    </HorizontalScrollView>

                    <!-- AGREGAR FOTOS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Información de la Mascota"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- FILA: Edad + Estado -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <Spinner
                                android:id="@+id/spinnerEdad"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingStart="12dp"
                                android:paddingEnd="4dp"
                                android:spinnerMode="dropdown"
                                android:background="@null"
                                android:entries="@array/edades_mascota"
                                android:prompt="@string/edad_hint" />

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <Spinner
                                android:id="@+id/spinnerEstado"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingStart="12dp"
                                android:paddingEnd="4dp"
                                android:spinnerMode="dropdown"
                                android:background="@null"
                                android:entries="@array/estados_mascota"
                                android:prompt="@string/estado_hint" />

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- FILA: Tamaño + Fecha (ImageButton) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <!-- Tamaño -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <EditText
                                android:id="@+id/etTamano"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:hint="Tamaño"
                                android:textColorHint="#AAAAAA"
                                android:textColor="#000000"
                                android:textSize="13sp"
                                android:paddingStart="12dp"
                                android:inputType="text"
                                android:gravity="center_vertical" />

                        </androidx.cardview.widget.CardView>

                        <!-- Fecha con ImageButton calendario -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="42dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent">

                                <TextView
                                    android:id="@+id/tvFecha"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_toStartOf="@+id/btnCalendario"
                                    android:gravity="center_vertical"
                                    android:paddingStart="12dp"
                                    android:text="Fecha"
                                    android:textColor="#AAAAAA"
                                    android:textSize="13sp" />

                                <ImageButton
                                    android:id="@+id/btnCalendario"
                                    android:layout_width="38dp"
                                    android:layout_height="38dp"
                                    android:layout_alignParentEnd="true"
                                    android:layout_centerVertical="true"
                                    android:layout_marginEnd="4dp"
                                    android:background="@null"
                                    android:contentDescription="Seleccionar fecha"
                                    android:padding="6dp"
                                    android:src="@drawable/ic_calendar_today_24"
                                    app:tint="#D79149" />

                            </RelativeLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <!-- DESCRIPCIÓN -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/etDescripcion"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:background="@null"
                            android:hint="Descripción (características de la mascota, especificaciones, como sucedió, algún dato importante)."
                            android:textColorHint="#AAAAAA"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:padding="12dp"
                            android:inputType="textMultiLine"
                            android:gravity="top|start"
                            android:scrollbars="vertical" />

                    </androidx.cardview.widget.CardView>

                    <!-- ÚLTIMA VEZ VISTO -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="Ultima vez visto:"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- MAPA -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardMapa"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:layout_marginBottom="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="4dp">

                        <fragment
                            android:id="@+id/mapFragment"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                    </androidx.cardview.widget.CardView>

                    <!-- CAMPO DIRECCIÓN (se llena al tocar el mapa) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginEnd="8dp"
                                android:src="@drawable/ic_location_on_24"
                                app:tint="#D79149" />

                            <TextView
                                android:id="@+id/tvDireccionSeleccionada"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Toca el mapa para registrar la dirección"
                                android:textColorHint="#AAAAAA"
                                android:textColor="#333333"
                                android:textSize="13sp" />

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- NOTA ADICIONAL -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/etNotaAdicional"
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:background="@null"
                            android:hint="Escriba aquí una nota importante que quieras mostrar en el reporte"
                            android:textColorHint="#AAAAAA"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:padding="12dp"
                            android:inputType="textMultiLine"
                            android:gravity="top|start" />

                    </androidx.cardview.widget.CardView>

                    <!-- RECOMPENSA -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <EditText
                            android:id="@+id/etRecompensa"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="Recompensa ofrecida (opcional)"
                            android:textColorHint="#AAAAAA"
                            android:textColor="#000000"
                            android:textSize="13sp"
                            android:padding="12dp"
                            android:inputType="text"
                            android:minHeight="48dp" />

                    </androidx.cardview.widget.CardView>

                    <!-- BOTÓN GUARDAR (rojo) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnGuardar"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="10dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#D32F2F">

                        <TextView
                            android:id="@+id/SalirReporte"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Salir"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </androidx.cardview.widget.CardView>

                    <!-- BOTÓN REALIZAR REPORTE (verde) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnRealizarReporte"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#388E3C">

                        <TextView
                            android:id="@+id/GuardarReporte"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Realizar reporte"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </androidx.cardview.widget.CardView>



                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>