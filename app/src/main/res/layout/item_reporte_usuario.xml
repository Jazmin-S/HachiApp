<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFF8F0">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Foto de la mascota en el historial -->
        <ImageView
            android:id="@+id/imgHistorialMascota"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:scaleType="centerCrop"
            android:src="@drawable/images"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Nombre de la Mascota -->
        <TextView
            android:id="@+id/txtHistorialNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Nombre Mascota"
            android:textColor="#2d1a00"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/imgHistorialMascota"
            app:layout_constraintEnd_toStartOf="@id/txtHistorialEstado"
            app:layout_constraintTop_toTopOf="@id/imgHistorialMascota" />

        <!-- Fecha de creación del reporte -->
        <TextView
            android:id="@+id/txtHistorialFecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="Creado: 12/05/2026"
            android:textColor="#6b4c2a"
            android:textSize="13sp"
            app:layout_constraintStart_toEndOf="@id/imgHistorialMascota"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtHistorialNombre" />

        <!-- Ubicación de referencia -->
        <TextView
            android:id="@+id/txtHistorialUbicacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:text="Ubicación registrada"
            android:textColor="#555555"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/imgHistorialMascota"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtHistorialFecha" />

        <!-- Estado del Reporte (Activo / Resuelto) -->
        <TextView
            android:id="@+id/txtHistorialEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="ACTIVO"
            android:textColor="#C62828"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/imgHistorialMascota" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>